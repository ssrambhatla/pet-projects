---
import Layout from '../layouts/Layout.astro';

const title = 'In-Home Pediatric Sleep Consultant Palo Alto | Calm & Courageous Sleepers';
const description = 'Private in-home pediatric sleep consultant serving Palo Alto families. Data-driven sleep architecture, bespoke overnight residency, and nursery environment engineering for discerning parents in Palo Alto, Menlo Park, and Stanford.';
const canonical = 'https://calmandcourageoussleepers.com/in-home-pediatric-sleep-consultant-palo-alto';
---

<Layout title={title} description={description} canonical={canonical}>
  <header class="sticky top-0 z-50 border-b border-moss/10 bg-cream/95 backdrop-blur-md">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="font-serif text-xl font-semibold tracking-tight text-moss">Calm & Courageous Sleepers</a>
      <div class="hidden items-center gap-8 text-sm font-medium text-ink/80 md:flex">
        <a href="/#services" class="hover:text-gold transition-colors">Concierge Services</a>
        <a href="/#about" class="hover:text-gold transition-colors">About Divya</a>
        <a href="/#faq" class="hover:text-gold transition-colors">FAQ</a>
        <a href="/#consultation" class="rounded-full bg-moss px-6 py-2.5 text-white shadow-luxury hover:bg-ink transition-colors">Request a Private Consultation</a>
      </div>
    </nav>
  </header>

  <main>
    <section class="relative overflow-hidden px-6 py-24 md:py-32">
      <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,#e8d5d0,transparent_30%),radial-gradient(circle_at_bottom_right,#dce9df,transparent_28%)]"></div>
      <div class="mx-auto max-w-4xl text-center">
        <p class="mb-6 inline-flex items-center gap-2 rounded-full bg-white/80 px-5 py-2.5 text-sm font-medium text-moss shadow-luxury">
          <span class="h-2 w-2 rounded-full bg-gold"></span>
          Serving Palo Alto · Menlo Park · Stanford
        </p>
        <h1 class="font-serif text-4xl font-semibold leading-[1.1] tracking-tight text-ink md:text-6xl">
          In-Home Pediatric Sleep Consultant in Palo Alto
        </h1>
        <p class="mt-8 text-lg leading-8 text-ink/70">
          Private, data-driven sleep concierge for Palo Alto families. From Professorville to Crescent Park to Old Palo Alto — Divya brings bespoke overnight immersion and sleep architecture directly to your home, so your household can finally rest.
        </p>
        <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
          <a href="/#consultation" class="rounded-full bg-moss px-8 py-4 text-center font-semibold text-white shadow-luxury hover:bg-ink transition-colors">Apply for Concierge Care</a>
          <a href="/#services" class="rounded-full border border-moss/30 bg-white/80 px-8 py-4 text-center font-semibold text-moss hover:border-moss transition-colors">View Concierge Services</a>
        </div>
      </div>
    </section>

    <section class="bg-white px-6 py-24">
      <div class="mx-auto max-w-4xl space-y-6 text-lg leading-8 text-ink/70">
        <h2 class="font-serif text-3xl font-semibold text-ink md:text-4xl">Why Palo Alto Families Choose Sleep Architecture</h2>
        <p>
          Palo Alto parents are engineers, founders, professors, and physicians. You think in systems, you value evidence, and you don't have time for vague coaching advice. That's exactly why Sleep Architecture resonates.
        </p>
        <p>
          Rather than generic sleep training, I treat your child's sleep as an optimizable system. I analyze circadian biology, feeding patterns, environmental conditions, and developmental milestones — then engineer a precision plan with measurable outcomes. For families in Palo Alto who want total delegation, the Bespoke In-Home Sleep Residency means I personally handle overnight execution so you can finally sleep.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl bg-cream p-6 ring-1 ring-moss/10">
            <h3 class="font-serif text-xl font-semibold text-moss">Bespoke In-Home Residency</h3>
            <p class="mt-2 text-sm text-ink/60">Complete overnight immersion with Divya personally handling execution, environment design, and biometric tracking for the first 3 nights.</p>
          </div>
          <div class="rounded-2xl bg-cream p-6 ring-1 ring-moss/10">
            <h3 class="font-serif text-xl font-semibold text-moss">Nursery Environment Engineering</h3>
            <p class="mt-2 text-sm text-ink/60">Lighting, temperature, acoustics, and air quality optimization for your child's sleep space — backed by sleep science.</p>
          </div>
          <div class="rounded-2xl bg-cream p-6 ring-1 ring-moss/10">
            <h3 class="font-serif text-xl font-semibold text-moss">Nanny & Staff Coordination</h3>
            <p class="mt-2 text-sm text-ink/60">Training and handoff protocols for your existing household staff to ensure seamless, consistent sleep execution.</p>
          </div>
          <div class="rounded-2xl bg-cream p-6 ring-1 ring-moss/10">
            <h3 class="font-serif text-xl font-semibold text-moss">Reflux & Special Needs Expertise</h3>
            <p class="mt-2 text-sm text-ink/60">Clinical-grade structural adjustments for infants with reflux, special needs, or medical considerations.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink md:text-3xl">Serving Palo Alto's Finest Neighborhoods</h2>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          {['Old Palo Alto', 'Crescent Park', 'Professorville', 'Palo Alto Hills', 'Midtown', 'Southgate', 'College Terrace', 'Barron Park'].map((area) => (
            <span class="rounded-full border border-moss/20 bg-white px-5 py-2 text-sm font-medium text-ink/70 shadow-luxury">{area}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white px-6 py-24">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="font-serif text-3xl font-semibold tracking-tight text-ink md:text-4xl">Ready to reclaim your nights?</h2>
        <p class="mt-5 text-lg text-ink/70">Begin with a private consultation. Divya will personally assess your family's needs and recommend the right path to restorative sleep.</p>
        <a href="/#consultation" class="mt-8 inline-block rounded-full bg-moss px-8 py-4 font-semibold text-white shadow-luxury hover:bg-ink transition-colors">Apply for Concierge Care</a>
      </div>
    </section>
  </main>

  <footer class="border-t border-moss/10 bg-white px-6 py-10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 text-sm text-ink/50 md:flex-row">
      <p>Copyright © 2025 Calm and Courageous Sleepers. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/in-home-pediatric-sleep-consultant-palo-alto" class="hover:text-moss transition-colors">Palo Alto</a>
        <a href="/concierge-baby-sleep-specialist-atherton-ca" class="hover:text-moss transition-colors">Atherton</a>
        <a href="/private-newborn-sleep-training-marin-county" class="hover:text-moss transition-colors">Marin County</a>
        <a href="/luxury-in-home-overnight-sleep-coach-san-francisco" class="hover:text-moss transition-colors">San Francisco</a>
      </div>
    </div>
  </footer>
</Layout>
