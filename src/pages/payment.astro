---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const title = 'Payment | Calm & Courageous Sleepers';
const description = 'Complete your payment with Divya.';
const canonical = 'https://calmandcourageoussleepers.com/payment';

const isVirtual = Astro.url.searchParams.has('virtual');
const serviceName = isVirtual ? 'Virtual Sleep Concierge Program' : 'Private Ask Me Anything Session';
const serviceDesc = isVirtual ? 'Data-driven remote sleep optimization program' : '45-minute private one-on-one call (virtual)';
const amount = isVirtual ? '$575' : '$150';
const amountDisplay = isVirtual ? '$575.00' : '$150.00';
---

<Layout title={title} description={description} canonical={canonical}>
  <header class="sticky top-0 z-50 border-b border-moss/10 bg-cream/95 backdrop-blur-md">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="font-serif text-xl font-semibold tracking-tight text-moss">Calm & Courageous Sleepers</a>
      <div class="hidden items-center gap-8 text-sm font-medium text-ink/80 md:flex">
        <a href="/#services" class="hover:text-gold transition-colors">Concierge Services</a>
        <a href="/#about" class="hover:text-gold transition-colors">About Divya</a>
        <a href="/#faq" class="hover:text-gold transition-colors">FAQ</a>
      </div>
    </nav>
  </header>

  <main>
    <section class="relative overflow-hidden px-6 py-16 md:py-24">
      <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,#e8d5d0,transparent_30%),radial-gradient(circle_at_bottom_right,#dce9df,transparent_28%)]"></div>
      <div class="mx-auto max-w-2xl">
        <div class="text-center">
          <p class="mb-4 inline-flex items-center gap-2 rounded-full bg-white/80 px-5 py-2.5 text-sm font-medium text-moss shadow-luxury">
            <span class="h-2 w-2 rounded-full bg-gold"></span>
            Step 2 of 2 — Complete Payment
          </p>
          <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink md:text-4xl">Complete Your Payment</h1>
          <p class="mt-4 text-lg leading-8 text-ink/70">
            You're almost there. Complete your payment below to confirm your {serviceName} with Divya.
          </p>
        </div>

        <!-- Order Summary -->
        <div class="mt-10 rounded-[2rem] bg-white/80 p-8 shadow-luxury ring-1 ring-moss/10">
          <h2 class="font-serif text-xl font-semibold text-ink">Order Summary</h2>
          <div class="mt-6 space-y-4">
            <div class="flex items-center justify-between border-b border-moss/10 pb-4">
              <div>
                <p class="font-semibold text-ink">{serviceName}</p>
                <p class="mt-1 text-sm text-ink/50">{serviceDesc}</p>
              </div>
              <p class="font-serif text-2xl font-semibold text-moss">{amount}</p>
            </div>
            <div class="flex items-center justify-between">
              <p class="text-sm font-medium text-ink/60">Total Due Today</p>
              <p class="font-serif text-2xl font-semibold text-moss">{amountDisplay}</p>
            </div>
          </div>
        </div>

        <!-- Helcim Payment Form -->
        <div class="mt-8 rounded-[2rem] bg-white/80 p-8 shadow-luxury ring-1 ring-moss/10">
          <h2 class="font-serif text-xl font-semibold text-ink">Payment Details</h2>
          <p class="mt-2 text-sm text-ink/50">Secure payment processed by Helcim. Your card information is encrypted and never stored on our servers.</p>

          <!-- HelcimPay.js Script -->
          <script type="text/javascript" src="https://secure.helcim.app/helcim-pay/services/start.js"></script>

          <!-- Pay Now Button -->
          <div class="mt-6">
            <button id="helcim-pay-btn" class="block w-full rounded-full bg-moss px-8 py-4 text-center font-semibold text-white shadow-luxury hover:bg-ink transition-colors">
              Pay {amountDisplay} Now
            </button>
          </div>

          <!-- Payment Status Messages -->
          <div id="helcim-success" class="mt-6 hidden rounded-xl bg-sage/10 p-6 text-center ring-1 ring-moss/10">
            <p class="font-serif text-xl font-semibold text-moss">Payment Successful!</p>
            <p class="mt-2 text-sm text-ink/60">Your session is confirmed. Divya will be in touch shortly.</p>
            <a href="/" class="mt-4 inline-block text-sm font-medium text-moss hover:text-gold transition-colors">Return to home →</a>
          </div>

          <div id="helcim-error" class="mt-6 hidden rounded-xl bg-red-50 p-6 text-center ring-1 ring-red-100">
            <p class="font-semibold text-red-700">Payment Failed</p>
            <p id="helcim-error-msg" class="mt-2 text-sm text-red-600"></p>
            <button id="helcim-retry" class="mt-4 text-sm font-medium text-moss hover:text-gold transition-colors">Try again</button>
          </div>

          <div id="helcim-loading" class="mt-6 hidden rounded-xl bg-cream p-6 text-center">
            <p class="text-sm font-medium text-ink/50">Preparing secure payment form...</p>
          </div>
        </div>

        <!-- HelcimPay.js Integration Script -->
        <script is:inline define:vars={{ amountNumeric: isVirtual ? '575.00' : '150.00' }}>
          let checkoutToken = null;
          let secretToken = null;

          const payBtn = document.getElementById('helcim-pay-btn');
          const loadingDiv = document.getElementById('helcim-loading');
          const successDiv = document.getElementById('helcim-success');
          const errorDiv = document.getElementById('helcim-error');
          const errorMsg = document.getElementById('helcim-error-msg');
          const retryBtn = document.getElementById('helcim-retry');

          async function initializeHelcimPay() {
            loadingDiv.classList.remove('hidden');
            payBtn.classList.add('hidden');
            errorDiv.classList.add('hidden');

            try {
              const response = await fetch('/api/helcim-init', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount: amountNumeric, currency: 'USD' }),
              });

              const data = await response.json();

              if (!response.ok) {
                throw new Error(data.error || 'Failed to initialize payment');
              }

              checkoutToken = data.checkoutToken;
              secretToken = data.secretToken;

              loadingDiv.classList.add('hidden');
              payBtn.classList.remove('hidden');

              // Render the HelcimPay.js modal
              appendHelcimPayIframe(checkoutToken);
            } catch (err) {
              loadingDiv.classList.add('hidden');
              errorDiv.classList.remove('hidden');
              errorMsg.textContent = err.message || 'Unable to start payment. Please try again.';
            }
          }

          // Listen for HelcimPay.js iframe events
          window.addEventListener('message', (event) => {
            if (!checkoutToken) return;

            const helcimPayJsIdentifierKey = 'helcim-pay-js-' + checkoutToken;

            if (event.data.eventName === helcimPayJsIdentifierKey) {
              if (event.data.eventStatus === 'SUCCESS') {
                payBtn.classList.add('hidden');
                successDiv.classList.remove('hidden');
                // Remove the iframe after success
                if (typeof removeHelcimPayIframe === 'function') {
                  removeHelcimPayIframe();
                }
              }

              if (event.data.eventStatus === 'ABORTED') {
                errorDiv.classList.remove('hidden');
                errorMsg.textContent = event.data.eventMessage || 'Payment was declined. Please try again.';
                payBtn.classList.remove('hidden');
              }

              if (event.data.eventStatus === 'HIDE') {
                payBtn.classList.remove('hidden');
              }
            }
          });

          payBtn.addEventListener('click', initializeHelcimPay);
          retryBtn.addEventListener('click', initializeHelcimPay);
        </script>

        <!-- Trust Badges -->
        <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-sm text-ink/40">
          <span class="flex items-center gap-2"><span class="text-gold">✦</span> 256-bit SSL encryption</span>
          <span class="flex items-center gap-2"><span class="text-gold">✦</span> PCI compliant</span>
          <span class="flex items-center gap-2"><span class="text-gold">✦</span> Secure payment by Helcim</span>
        </div>

        <!-- Back link -->
        <div class="mt-8 text-center">
          <a href="/" class="text-sm font-medium text-ink/50 hover:text-moss transition-colors">← Back to home</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-moss/10 bg-white px-6 py-10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 text-sm text-ink/50 md:flex-row">
      <p>Copyright © 2025 Calm and Courageous Sleepers. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/in-home-pediatric-sleep-consultant-palo-alto" class="hover:text-moss transition-colors">Palo Alto</a>
        <a href="/concierge-baby-sleep-specialist-atherton-ca" class="hover:text-moss transition-colors">Atherton</a>
        <a href="/private-newborn-sleep-training-marin-county" class="hover:text-moss transition-colors">Marin County</a>
        <a href="/luxury-in-home-overnight-sleep-coach-san-francisco" class="hover:text-moss transition-colors">San Francisco</a>
      </div>
    </div>
  </footer>
</Layout>
